      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 5844712802128595180, guid: 028f129783643b64abf99facaa2c8c45, type: 3}
      propertyPath: texts.Array.data[0]
      value: "\u4F60\u6C38\u8FDC\u4E0D\u4F1A\u5FD8\u8BB01994\u5E74\u51AC\u5929\u7684\u90A3\u4E2A\u65E9\u6668\u3002\n\u90A3\u65F6\uFF0C\u4F60\u8FD8\u662F\u4E2A\u8B66\u5BDF\u3002\n\u4E0A\u5348\u516D\u70B9\uFF0C\u4F60\u63A5\u5230\u4E86\u62A5\u6848\uFF0C\u6765\u5230\u4E86\u6848\u53D1\u73B0\u573A\u2026\u2026\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5844712802128595180, guid: 028f129783643b64abf99facaa2c8c45, type: 3}
      propertyPath: texts.Array.data[1]
      value: "\u62A5\u6848\u4EBA\u53EB\u6797\u79C0\u534E\uFF0C\u6B7B\u8005\u7684\u59BB\u5B50\u3002\n\u5979\u5C31\u50CF\u6240\u6709\u4E27\u5076\u7684\u59BB\u5B50\u4E00\u6837\uFF0C\u773C\u775B\u54ED\u5F97\u7EA2\u80BF\uFF1A\n\u201C\u6211\u4ECA\u5929\u50CF\u5F80\u5E38\u4E00\u6837\u8D77\u5E8A\u70E7\u6C34\uFF0C\u5374\u53D1\u73B0\u5367\u5BA4\u95E8\u5F00\u7740\uFF0C\u6211\u4E08\u592B\u4ED6\u2026\u2026\u201D\n\u6797\u79C0\u534E\u6342\u7740\u8138\uFF0C\u555C\u6CE3\u58F0\u4ECE\u6307\u7F1D\u4E2D\u6F0F\u51FA\uFF0C\u5979\u653E\u4E0B\u624B\u65F6\uFF0C\u8138\u8272\u5DF2\u7ECF\u6062\u590D\u4E86\u9547\u9759\uFF1A\n\u201C\u6211\u4E08\u592B\u4ED6\u662F\u4E2A\u597D\u4EBA\uFF0C\u5E73\u65F6\u6CA1\u4EC0\u4E48\u4EC7\u3002\u4F46\u6628\u665A\u4ED6\u5728\u5BA2\u5385\u8DDF\u4EBA\u5927\u5435\u4E00\u67B6\u3002\u201D\n\u201C\u6628\u665A\u6765\u4E86\u4E24\u4E2A\u4EBA\u3002\u5148\u6765\u7684\u662F\u536B\u56FD\u5F3A\uFF0C\u5C31\u662F\u6C99\u53D1\u4E0A\u5750\u7740\u7684\u90A3\u4F4D\u3002\u4ED6\u8DDF\u6211\u7537\u4EBA\u5728\u5BA2\u5385\u8BF4\u8BDD\uFF0C\u8981\u4EC0\u4E48\u4E1C\u897F\u3002\u201C\n\u201D\u540E\u6765\u90A3\u4E2A\u5E74\u8F7B\u5C0F\u5B50\u4E5F\u6765\u4E86\uFF0C\u53EB\u5F20\u94C1\u67F1\uFF0C\u5728\u5367\u5BA4\u90A3\u8FB9\u7AD9\u7740\u5462\u3002\u4ED6\u4EEC\u5435\u4E86\u4E00\u9635\u3002\u536B\u56FD\u5F3A\u5148\u8D70\u7684\uFF0C\u5F20\u94C1\u67F1\u5728\u540E\u9762\u4E5F\u8DD1\u4E86\u3002\u6211\u5403\u4E86\u836F\uFF0C\u7761\u5F97\u65E9\uFF0C\u540E\u6765\u7684\u4E8B\u6211\u6CA1\u542C\u89C1\u3002\u201D\n\u201C\u6211\u62A5\u4E86\u8B66\u3002\u7136\u540E\u5C31\u7AD9\u5728\u8FD9\u91CC\u7B49\u7740\u3002\u6CA1\u518D\u8FDB\u53BB\u8FC7\u3002\u201D\n"
      objectReference: {fileID: 0}
